{
  "name": "novel-scraper-desktop",
  "productName": "UNS",
  "description": "Desktop app for scraping web novels into EPUB format",
  "version": "1.0.0",
  "main": "main.js",
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run start:frontend\" \"wait-on http://localhost:5173 && npm run start:electron\"",
    "start:frontend": "cd frontend && npm run dev",
    "start:electron": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "build": "cd frontend && npm run build && electron-builder"
  },
  "build": {
    "appId": "com.universalnovelscraper.app",
    "productName": "UNS",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
