{
  "name": "novel-scraper-desktop",
  "productName": "UNS",
  "description": "Desktop app for scraping web novels into EPUB format",
  "version": "1.0.0",
  "author": "Osama",
  "main": "main.js",
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run start:frontend\" \"wait-on http://localhost:5173 && npm run start:electron\"",
    "start:frontend": "cd frontend && npm run dev",
    "start:electron": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:electron": "electron-builder",
    "build": "npm run build:frontend && npm run build:electron"
  },
  "build": {
    "appId": "com.universalnovelscraper.app",
    "productName": "UNS",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/icon.png",
      "frontend/dist/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "bin",
        "filter": [
          "engine",
          "engine.exe"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}